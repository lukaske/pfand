# ───────────────────────────────────────────────────────────────────────────
# Pfand environment. Copy to .env and fill. Nothing here is committed.
# ───────────────────────────────────────────────────────────────────────────

# ── Arc Testnet (Block B — PROTECTED) ──────────────────────────────────────
ARC_RPC_URL=https://rpc.testnet.arc.network
# Deployer key for contracts + agent wallets. Fund with testnet USDC (gas = USDC):
#   faucet: https://faucet.circle.com
PRIVATE_KEY=
USDC_ADDRESS=0x3600000000000000000000000000000000000000
TREASURY=                      # optional; defaults to deployer

# Filled by `forge script script/Deploy.s.sol` output:
ARC_IDENTITY_REGISTRY=
ARC_REPUTATION_REGISTRY=
ARC_VALIDATION_REGISTRY=
ARC_REBATE_ESCROW=
ARC_USDC=0x3600000000000000000000000000000000000000

# ── Circle Agent Stack / Nanopayments (Block B) ────────────────────────────
CIRCLE_API_KEY=                # Circle Developer console
CIRCLE_ENTITY_SECRET=          # for Programmable Wallets, if used
CIRCLE_GATEWAY_URL=https://gateway-api-testnet.circle.com

# ── Anthropic (Claude-backed agents + NL search) ───────────────────────────
ANTHROPIC_API_KEY=

# ── Supabase (the unified index) ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=     # server-only; ingest writes

# ── Google Cloud / BigQuery (Block C) ──────────────────────────────────────
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json   # path to SA key

# ── ENS (Block D) ──────────────────────────────────────────────────────────
SEPOLIA_RPC_URL=
ENS_PARENT_NAME=broker8004.eth         # parent registered on Sepolia first
ENS_GATEWAY_SIGNER_KEY=                # signs CCIP-Read responses
ENS_OFFCHAIN_RESOLVER=                 # deployed resolver address
ETHERSCAN_API_KEY=
