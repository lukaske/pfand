# =============================================================================
# Pfand indexer environment. Copy to .env and fill in. None are needed for
# `npm run bigquery:dry` / `tsx src/arc-listener.ts --dry-run`.
# =============================================================================

# ---- Google BigQuery (mainnet ERC-8004 indexing) ----------------------------
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Absolute path to a service-account JSON key with BigQuery Job User on the project.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# Optional: partition-prune start date for the public dataset (ERC-8004 launch).
BQ_SINCE=2026-01-28

# ---- Supabase (write target) ------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SERVICE ROLE key (server-side only — never ship to the browser).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Arc Testnet listener ---------------------------------------------------
ARC_RPC_URL=https://rpc.testnet.arc.network
# Block to backfill from (set to the RebateEscrow deploy block to save RPC calls).
ARC_FROM_BLOCK=0
# Our Arc deployment (filled by contracts/script/Deploy.s.sol). Required to run arc-listener.
ARC_IDENTITY_REGISTRY=0x...
ARC_REPUTATION_REGISTRY=0x...
ARC_VALIDATION_REGISTRY=0x...
ARC_REBATE_ESCROW=0x...
# Optional: defaults to the canonical Arc USDC if unset.
ARC_USDC=0x3600000000000000000000000000000000000000

# ---- Embeddings -------------------------------------------------------------
# "deterministic" (default, offline, zero-cost) or a provider you wire in embed.ts.
PFAND_EMBED_PROVIDER=deterministic

# ---- Misc -------------------------------------------------------------------
# IPFS gateway for resolving ipfs:// agent cards.
IPFS_GATEWAY=https://ipfs.io/ipfs/
