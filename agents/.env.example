# ── Pfand agents — Arc Testnet autonomous payment loop ───────────────────────
# Copy to `agents/.env` and fill in once you have a funded Arc Testnet key.
# Faucet: https://faucet.circle.com   |   Chain id: 5042002

# --- Chain / signer ---
# Arc Testnet RPC (defaults to the public RPC in @pfand/shared if omitted).
ARC_RPC_URL=https://rpc.testnet.arc.network
# 32-byte hex private key (with or without 0x). Funds the buyer AND, by default,
# acts as the seller wallet + agent owner. Use a throwaway key.
PRIVATE_KEY=

# --- Deployed contract addresses (from contracts/ deploy script) ---
ARC_REBATE_ESCROW=
ARC_IDENTITY_REGISTRY=
ARC_REPUTATION_REGISTRY=
# Optional — falls back to the canonical Arc USDC if omitted.
ARC_USDC=0x3600000000000000000000000000000000000000
# Only needed if you call loadArcDeployment elsewhere; not required by the loop.
ARC_VALIDATION_REGISTRY=

# --- Anthropic (real Claude-backed agent work) ---
# Without this, the service agent returns a clearly-marked stub instead.
ANTHROPIC_API_KEY=
# Optional model override.
ANTHROPIC_MODEL=claude-opus-4-8

# --- Circle x402 / Gateway ---
# Optional API key if your facilitator requires auth headers.
CIRCLE_API_KEY=
# Override the facilitator URL (default: https://gateway-api-testnet.circle.com).
CIRCLE_GATEWAY_URL=https://gateway-api-testnet.circle.com

# --- Service agent (seller) ---
PORT=8402
# Wallet that receives x402 payments (defaults to address from PRIVATE_KEY).
SERVICE_WALLET=
# Public base URL used in registration cards + by the loop. If set, agents are
# registered with their http endpoint; if unset, a data: URI card is used.
SERVICE_BASE_URL=http://localhost:8402
# Comma list of personas to expose (default: all). Keys: auditor,gasOptimizer,docWriter
AGENT_PERSONAS=

# --- Buyer target (client-agent.ts when run standalone) ---
TARGET_AGENT_ID=
TARGET_SERVICE_WALLET=
TARGET_ENDPOINT=http://localhost:8402/audit
TARGET_FEE_USDC=0.05
TARGET_SCORE=92
FEEDBACK_WINDOW_SECS=86400
# Optional override of the material sent to the agent.
TARGET_INPUT=
